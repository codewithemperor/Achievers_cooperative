{
  "name": "achievers-cooperative",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:landing": "pnpm --filter landing dev",
    "dev:member": "pnpm --filter member-pwa dev",
    "dev:admin": "pnpm --filter admin-web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter api prisma generate",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api prisma db seed"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "prettier": "3.6.2",
    "turbo": "2.5.6",
    "typescript": "5.9.2"
  }
}
