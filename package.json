{
  "name": "achievers-cooperative",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm exec turbo run dev",
    "dev:landing": "pnpm --filter landing dev",
    "dev:member": "pnpm --filter member-pwa dev",
    "dev:admin": "pnpm --filter admin-web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm exec turbo run build",
    "lint": "pnpm exec turbo run lint",
    "test": "pnpm exec turbo run test",
    "typecheck": "pnpm exec turbo run typecheck",
    "format": "pnpm exec turbo run format",
    "db:generate": "pnpm --filter api prisma generate",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api prisma db seed"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "caniuse-lite": "1.0.30001787",
    "prettier": "3.8.1",
    "source-map": "0.7.6",
    "turbo": "2.9.5",
    "typescript": "6.0.2"
  }
}
