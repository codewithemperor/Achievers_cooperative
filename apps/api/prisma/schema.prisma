generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"

}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AUDITOR
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum TransactionType {
  FUNDING
  SAVINGS
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  INVESTMENT
  WALLET_FUNDING
  MEMBERSHIP_CHARGE
  INVESTMENT_DEPOSIT
  INVESTMENT_RETURN
  PACKAGE_SUBSCRIPTION
  PACKAGE_PENALTY
}

enum CooperativeEntryType {
  INCOME
  EXPENSE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                     String      @id @default(cuid())
  email                  String      @unique
  passwordHash           String
  role                   UserRole
  tempActivationCodeHash String?
  tempCodeExpiry         DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  member                 Member?
  notifications          Notification[]
  auditEvents            AuditEvent[] @relation("AuditActor")
  verifiedPayments       Payment[]   @relation("PaymentVerifier")
  cooperativeEntries     CooperativeEntry[]
}

model Member {
  id                   String                 @id @default(cuid())
  userId               String                 @unique
  membershipNumber     String                 @unique
  fullName             String
  phoneNumber          String
  address              String?
  avatarUrl            String?
  status               MemberStatus           @default(PENDING)
  joinedAt             DateTime               @default(now())
  user                 User                   @relation(fields: [userId], references: [id])
  wallet               Wallet?
  savingsAccounts      SavingsAccount[]
  loanApplications     LoanApplication[]
  investments          InvestmentSubscription[]
  payments             Payment[]
  packageSubscriptions PackageSubscription[]
}

model Wallet {
  id               String        @id @default(cuid())
  memberId         String        @unique
  availableBalance Decimal       @default(0)
  pendingBalance   Decimal       @default(0)
  totalFunded      Decimal       @default(0)
  totalCharges     Decimal       @default(0)
  currency         String        @default("NGN")
  member           Member        @relation(fields: [memberId], references: [id])
  transactions     Transaction[]
}

model Transaction {
  id         String          @id @default(cuid())
  walletId   String
  type       TransactionType
  amount     Decimal
  status     ApprovalStatus  @default(PENDING)
  reference  String?         @unique
  createdAt  DateTime        @default(now())
  wallet     Wallet          @relation(fields: [walletId], references: [id])
}

model SavingsAccount {
  id                    String   @id @default(cuid())
  memberId              String
  balance               Decimal  @default(0)
  contributionFrequency String
  member                Member   @relation(fields: [memberId], references: [id])
}

model LoanApplication {
  id               String         @id @default(cuid())
  memberId         String
  amount           Decimal
  tenorMonths      Int
  purpose          String
  status           ApprovalStatus @default(PENDING)
  submittedAt      DateTime       @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  disbursedAt      DateTime?
  remainingBalance Decimal        @default(0)
  member           Member         @relation(fields: [memberId], references: [id])
}

model InvestmentProduct {
  id              String   @id @default(cuid())
  name            String
  annualRate      Decimal
  minimumAmount   Decimal
  maximumAmount   Decimal?
  durationMonths  Int
  status          String   @default("ACTIVE")
  subscriptions   InvestmentSubscription[]
}

model InvestmentSubscription {
  id             String            @id @default(cuid())
  memberId       String
  productId      String
  principal      Decimal
  maturityDate   DateTime
  status         ApprovalStatus    @default(PENDING)
  member         Member            @relation(fields: [memberId], references: [id])
  product        InvestmentProduct @relation(fields: [productId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Payment {
  id              String         @id @default(cuid())
  memberId        String
  amount          Decimal
  receiptUrl      String?
  status          ApprovalStatus @default(PENDING)
  rejectionReason String?
  verifiedAt      DateTime?
  netCreditAmount Decimal?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  verifiedById    String?
  member          Member         @relation(fields: [memberId], references: [id])
  verifiedBy      User?          @relation("PaymentVerifier", fields: [verifiedById], references: [id])
}

model Package {
  id               String                @id @default(cuid())
  name             String
  totalAmount      Decimal
  durationMonths   Int
  penaltyType      String
  penaltyValue     Decimal
  penaltyFrequency String
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  subscriptions    PackageSubscription[]
}

model PackageSubscription {
  id             String   @id @default(cuid())
  packageId      String
  memberId       String
  amountPaid     Decimal  @default(0)
  amountRemaining Decimal
  penaltyAccrued Decimal  @default(0)
  status         String   @default("ACTIVE")
  nextDueAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  package        Package  @relation(fields: [packageId], references: [id])
  member         Member   @relation(fields: [memberId], references: [id])
}

model CooperativeWallet {
  id           String             @id @default(cuid())
  balance      Decimal            @default(0)
  totalIncome  Decimal            @default(0)
  totalExpense Decimal            @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  entries      CooperativeEntry[]
}

model CooperativeEntry {
  id          String               @id @default(cuid())
  walletId    String
  type        CooperativeEntryType
  amount      Decimal
  category    String
  description String
  reference   String?
  createdById String?
  createdAt   DateTime             @default(now())
  wallet      CooperativeWallet    @relation(fields: [walletId], references: [id])
  createdBy   User?                @relation(fields: [createdById], references: [id])
}
