{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec nest start --watch",
    "build": "pnpm exec nest build",
    "start": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "pnpm exec jest",
    "format": "prettier --check .",
    "prisma": "pnpm exec prisma",
    "prisma:push": "pnpm exec prisma db push ",
    "prisma:generate": "pnpm exec prisma generate",
    "prisma:migrate": "pnpm exec prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.6",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "7.7.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.18",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@prisma/config": "^7.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "30.3.0",
    "prisma": "7.7.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0"
  }
}
